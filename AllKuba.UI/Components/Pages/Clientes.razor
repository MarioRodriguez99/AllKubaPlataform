@page "/clientes"
@inject ApiService Api

<div class="page-header">
    <h2>Clientes</h2>
    <button class="btn btn-primary" @onclick="NuevoCliente">+ Nuevo cliente</button>
</div>

<div class="panel-dos-columnas">

    <!-- Lista -->
    <!-- Lista -->
    <div>
        @if (!ListaClientes.Any())
        {
            <p class="text-muted" style="padding:2rem;text-align:center">Sin clientes aún</p>
        }
        else
        {
            <table>
                <thead>
                    <tr><th>Nombre</th><th>Teléfonos</th><th>Email</th><th>Dirección</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var c in ListaClientes)
                    {
                        var cliente = c;
                        <tr>
                            <td><strong>@cliente.Nombre</strong></td>
                            <td>@cliente.TelefonosDisplay</td>
                            <td>@(string.IsNullOrEmpty(cliente.Email) ? "—" : cliente.Email)</td>
                            <td>@(string.IsNullOrEmpty(cliente.Direccion) ? "—" : cliente.Direccion)</td>
                            <td>
                                <div class="acciones">
                                    <button class="btn btn-sm" @onclick="() => Editar(cliente)">Editar</button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => Eliminar(cliente.Id)">✕</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    <!-- Formulario -->
    <div class="card">
        <h3>@(EditId.HasValue ? "Editar" : "Nuevo") cliente</h3>

        <div class="form-group">
            <label>Nombre *</label>
            <input @bind="Nombre" placeholder="Nombre completo" />
        </div>
        <div class="form-group">
            <label>Teléfonos</label>
            @for (int i = 0; i < Telefonos.Count; i++)
            {
                var idx = i;
                <div style="display:flex;gap:6px;margin-bottom:6px">
                    <input @bind="Telefonos[idx]" placeholder="+54 9 ..." style="flex:1" />
                    @if (Telefonos.Count > 1)
                    {
                        <button class="btn btn-sm btn-danger" @onclick="() => Telefonos.RemoveAt(idx)">✕</button>
                    }
                </div>
            }
            <button class="btn btn-sm" @onclick="AgregarTelefono">+ Teléfono</button>
        </div>
        <div class="form-group">
            <label>Email</label>
            <input @bind="Email" placeholder="email@ejemplo.com" />
        </div>
        <div class="form-group">
            <label>Dirección</label>
            <input @bind="Direccion" placeholder="Calle y número" />
        </div>

        <div class="acciones" style="margin-top:1rem">
            <button class="btn" @onclick="Limpiar">Cancelar</button>
            <button class="btn btn-primary" @onclick="Guardar">Guardar</button>
        </div>
    </div>
</div>

@code {
    List<Cliente> ListaClientes = [];
    int? EditId;
    string Nombre = "", Email = "", Direccion = "";
    List<string> Telefonos = [""];

    protected override async Task OnInitializedAsync() => await Cargar();

    async Task Cargar() => ListaClientes = await Api.GetClientesAsync();

    void NuevoCliente() => Limpiar();

    void AgregarTelefono() => Telefonos.Add("");

    void Editar(Cliente c)
    {
        EditId = c.Id;
        Nombre = c.Nombre;
        Telefonos = c.Telefonos.Any() ? [.. c.Telefonos] : [""];
        Email = c.Email;
        Direccion = c.Direccion;
    }

    async Task Guardar()
    {
        var req = new CrearClienteRequest(
            Nombre,
            Telefonos.Where(t => !string.IsNullOrWhiteSpace(t)).ToList(),
            Email,
            Direccion);

        if (EditId.HasValue)
            await Api.EditarClienteAsync(EditId.Value, req);
        else
            await Api.CrearClienteAsync(req);

        Limpiar();
        await Cargar();
    }

    async Task Eliminar(int id)
    {
        await Api.EliminarClienteAsync(id);
        await Cargar();
    }

    void Limpiar()
    {
        EditId = null;
        Nombre = Email = Direccion = "";
        Telefonos = [""];
    }
}

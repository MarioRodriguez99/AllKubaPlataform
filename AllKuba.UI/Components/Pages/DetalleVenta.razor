@page "/ventas/{Id:int}"
@inject ApiService Api
@inject NavigationManager Nav
@inject IJSRuntime JS

@if (Venta is null)
{
    <p class="text-muted">Cargando...</p>
}
else
{
    <!-- Controles — no se imprimen -->
    <div class="no-print">
        <div class="page-header">
            <div style="display:flex;align-items:center;gap:1rem">
                <button class="btn" @onclick="Volver">← Volver</button>
                <h2>@Venta.Numero</h2>
                <span class="badge badge-@Venta.Estado">@Venta.EstadoLabel</span>
            </div>
            <div class="acciones">
                <select class="btn btn-sm" @onchange="e => CambiarEstado(e.Value!.ToString()!)">
                    @foreach (var (key, label) in Estados)
                    {
                        <option value="@key" selected="@(Venta.Estado == key)">@label</option>
                    }
                </select>
                <button class="btn btn-sm" @onclick="ImprimirCotizacion">📄 Cotización</button>
                <button class="btn btn-sm" @onclick="ImprimirOrden">🔧 Orden producción</button>
            </div>
        </div>
    </div>

    <!-- Documento imprimible -->
    <div class="documento-print">

        <!-- Cabecera -->
        <div class="print-header">
            <div class="print-logo">
                <img src="data:image/png;base64," alt="AllKuba Ruiz" />
                <div>
                    <h1>AllKuba Ruiz</h1>
                    <p>Carpintería de Aluminio</p>
                </div>
            </div>
            <div class="print-doc-info">
                <h2 class="solo-cotizacion">COTIZACIÓN</h2>
                <h2 class="solo-produccion">ORDEN DE PRODUCCIÓN</h2>
                <table class="info-table">
                    <tr><td>Número:</td><td><strong>@Venta.Numero</strong></td></tr>
                    <tr><td>Fecha:</td><td>@Venta.FechaDisplay</td></tr>
                </table>
            </div>
        </div>

        <!-- Cliente -->
        <div class="print-section">
            <h3>CLIENTE</h3>
            <p><strong>@Venta.Cliente.Nombre</strong></p>
            @if (Venta.Cliente.Telefonos.Any())
            {
                <p>Tel: @Venta.Cliente.TelefonosDisplay</p>
            }
            @if (!string.IsNullOrEmpty(Venta.Cliente.Email))
            {
                <p>Email: @Venta.Cliente.Email</p>
            }
            @if (!string.IsNullOrEmpty(Venta.Cliente.Direccion))
            {
                <p>Dir: @Venta.Cliente.Direccion</p>
            }
        </div>

        <!-- Tabla de productos -->
        <div class="print-section">
            <h3>DETALLE</h3>
            <table class="print-table">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Producto</th>
                        <th>Medidas</th>
                        <th>Opciones</th>
                        <th>Cant.</th>
                        <th>Notas</th>
                        <th class="solo-cotizacion" style="text-align:right">P. Unit.</th>
                        <th class="solo-cotizacion" style="text-align:right">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Venta.Lineas.Count; i++)
                    {
                        var l = Venta.Lineas[i];
                        <tr>
                            <td>@(i + 1)</td>
                            <td><strong>@l.NombreProducto</strong></td>
                            <td>@l.MedidasDisplay</td>
                            <td style="font-size:11px">@l.VariantesDisplay</td>
                            <td>@l.Cantidad</td>
                            <td style="font-size:11px">@(string.IsNullOrEmpty(l.Notas) ? "—" : l.Notas)</td>
                            <td class="solo-cotizacion" style="text-align:right">$ @l.PrecioUnitario.ToString("F2")</td>
                            <td class="solo-cotizacion" style="text-align:right"><strong>$ @l.Subtotal.ToString("F2")</strong></td>
                        </tr>
                    }
                </tbody>
                <tfoot class="solo-cotizacion">
                    <tr>
                        <td colspan="6" style="text-align:right;font-weight:700">TOTAL USD</td>
                        <td colspan="2" style="text-align:right;font-size:16px;font-weight:700">$ @Venta.Total.ToString("F2")</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        @if (!string.IsNullOrEmpty(Venta.Observaciones))
        {
            <div class="print-section">
                <h3>OBSERVACIONES</h3>
                <p>@Venta.Observaciones</p>
            </div>
        }

        <!-- Firma (solo orden de producción) -->
        <div class="print-section solo-produccion" style="margin-top:3rem">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem">
                <div>
                    <div style="border-top:1px solid #000;padding-top:6px;margin-top:2rem">
                        <p style="font-size:11px">Firma responsable de producción</p>
                    </div>
                </div>
                <div>
                    <div style="border-top:1px solid #000;padding-top:6px;margin-top:2rem">
                        <p style="font-size:11px">Fecha de entrega</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="print-footer solo-cotizacion">
            <p>Válido por 30 días desde la fecha de emisión.</p>
        </div>
    </div>

    <!-- Vista normal (no impresión) -->
    <div class="no-print">
        <div class="card" style="margin-bottom:1rem">
            <p style="font-size:11px;font-weight:700;color:#888;margin-bottom:6px">CLIENTE</p>
            <p style="font-size:16px;font-weight:700">@Venta.Cliente.Nombre</p>
            @if (Venta.Cliente.Telefonos.Any())
            {
                <p style="font-size:13px;color:#555">Tel: @Venta.Cliente.TelefonosDisplay</p>
            }
            @if (!string.IsNullOrEmpty(Venta.Cliente.Email))
            {
                <p style="font-size:13px;color:#555">Email: @Venta.Cliente.Email</p>
            }
        </div>

        <div class="card" style="padding:0;overflow:hidden;margin-bottom:1rem">
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Producto</th>
                        <th>Medidas</th>
                        <th>Cant.</th>
                        <th>Opciones</th>
                        <th>Notas</th>
                        <th style="text-align:right">Unitario</th>
                        <th style="text-align:right">Subtotal</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Venta.Lineas.Count; i++)
                    {
                        var l = Venta.Lineas[i];
                        <tr>
                            <td>@(i + 1)</td>
                            <td><strong>@l.NombreProducto</strong></td>
                            <td>@l.MedidasDisplay</td>
                            <td>@l.Cantidad</td>
                            <td style="font-size:12px">@l.VariantesDisplay</td>
                            <td style="font-size:12px;color:#666">@(string.IsNullOrEmpty(l.Notas) ? "—" : l.Notas)</td>
                            <td style="text-align:right">$ @l.PrecioUnitario.ToString("F2")</td>
                            <td style="text-align:right"><strong>$ @l.Subtotal.ToString("F2")</strong></td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="7" style="text-align:right;font-weight:700;padding:12px">TOTAL USD</td>
                        <td style="text-align:right;font-size:20px;font-weight:700">$ @Venta.Total.ToString("F2")</td>
                    </tr>
                </tfoot>
            </table>
        </div>

        @if (!string.IsNullOrEmpty(Venta.Observaciones))
        {
            <div class="card">
                <p style="font-size:11px;font-weight:700;color:#888;margin-bottom:4px">OBSERVACIONES</p>
                <p>@Venta.Observaciones</p>
            </div>
        }
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    Venta? Venta;

    static readonly Dictionary<string, string> Estados = new()
    {
        { "pendiente",     "Pendiente" },
        { "aprobado",      "Aprobado" },
        { "en_produccion", "En producción" },
        { "entregado",     "Entregado" },
        { "cancelado",     "Cancelado" }
    };

    protected override async Task OnParametersSetAsync() =>
        Venta = await Api.GetVentaAsync(Id);

    void Volver() => Nav.NavigateTo("/ventas");

    async Task CambiarEstado(string estado)
    {
        await Api.CambiarEstadoAsync(Id, estado);
        Venta = await Api.GetVentaAsync(Id);
    }

    async Task ImprimirCotizacion() =>
        await JS.InvokeVoidAsync("imprimirCotizacion");

    async Task ImprimirOrden() =>
        await JS.InvokeVoidAsync("imprimirOrdenProduccion");
}
